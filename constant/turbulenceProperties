// EXTRACTED from DKS-MANAGER/2DPipelineScour/constant/turbulenceProperties.b
// Baseline fluid phase used k-omega SST -> replicated for single-phase.
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}

simulationType  RAS;

RAS
{
    RASModel    kOmegaSST;
    turbulence  on;
    printCoeffs on;
}

