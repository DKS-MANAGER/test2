// EXTRACTED from DKS-MANAGER/2DPipelineScour/constant/transportProperties
// Sediment (phase a): d50=0.36mm, rho_s=2650 kg/m3
//
// Derived parameters:
//   s   = rho_s / rho_f = 2.65
//   D*  = d50 * [(s-1)*g / nu^2]^(1/3)
//       = 3.6e-4 * [(1.65*9.81) / 1e-12]^(1/3) = 9.15
//   theta_cr (Soulsby 1997):
//       = 0.30/(1+1.2*D*) + 0.055*(1-exp(-0.020*D*))
//       = 0.30/10.98 + 0.055*(1-exp(-0.183)) = 0.0473
//
// Nielsen (1992) bedload:
//   qb* = 12 * sqrt(theta) * (theta - theta_cr)   [theta > theta_cr]
//   qb  = qb* * sqrt((s-1)*g*d50^3)
//       = qb* * sqrt(1.65*9.81*(3.6e-4)^3) = qb* * 1.48e-5 m2/s
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      sedimentProperties;
}

d50                 d50 [0 1 0 0 0 0 0]   3.6e-4;
rhoSediment         rhoSediment [1 -3 0 0 0 0 0] 2650;
specificGravity     specificGravity [0 0 0 0 0 0 0] 2.65;
porosity            porosity [0 0 0 0 0 0 0] 0.4;
thetaCr             thetaCr [0 0 0 0 0 0 0] 0.0473;
nielsenCoeff        nielsenCoeff [0 0 0 0 0 0 0] 12;
angleOfRepose       angleOfRepose [0 0 0 0 0 0 0] 32;
shapeFactor         shapeFactor [0 0 0 0 0 0 0] 1.0;
hindranceExp        hindranceExp [0 0 0 0 0 0 0] 2.65;

