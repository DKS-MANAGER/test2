// FIX: Added 'saturationType none' (was completely missing).
//
// bedload.H reads saturationType from this dict. With no keyword present,
// saturationType = "" which matches none of the three valid branches:
//   "implicit1D" | "explicit" | "none"
// â†’ falls into the else { FatalError } branch
// â†’ OpenFOAM FatalError raises SIGABRT, caught by trapFpe, printed as SIGFPE.
//
// PHASE 1 (spin-up, bedMotion off): 'none' is correct â€” qb = qsat directly.
// PHASE 2 (scour, bedMotion on): change to 'explicit' and add Lsat/Tsat.
//   saturationType   explicit;
//   Lsat             5e-3;   // 5 mm â€” Renaud et al. 2026, Sec 5.2.3
//   Tsat             0.01;   // 0.01 s
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      bedloadProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

sedimentBed             on;
sedimentBedPatches      (bottom);

// PHASE 1 (spin-up 0-2s): bedMotion OFF â€” mesh stays fixed while flow
// develops. Change to 'on' for Phase 2 (2-45s) restart.
bedMotion               off;

// Euler explicit (order 0): safe for cold start, no dVsed.oldTime() required.
ABorder                 0;

fixedFaPatches          ();

// SATURATION: 'none' for phase 1 (qb = qsat, no saturation equation).
// Switch to 'explicit' with Lsat/Tsat for phase 2 (Renaud et al. 2026).
saturationType          none;

bedloadModel
{
    type                Nielsen;
    alpha               7.2;
    aExp                0.5;
    bExp                1;
    slopeCorrecton      off;
    gamma               0.1;
    avalanche           on;
    Qav                 1e-3;
    alphaFiltBeta       0.1;
    NfiltBeta           1;
    coefShields         1;
}

criticalShieldsModel
{
    type                Soulsby;
    slopeCorrection     on;
}

morphoAccFactor         1;

filterExner             off;
alphaFiltExner          0.1;
NfiltExner              1;

rigidBed                off;

// ************************************************************************* //
