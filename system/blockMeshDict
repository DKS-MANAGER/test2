FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

scale   1.0;

vertices
(
    (-0.75    0.205      0.001) // 0: front-top-left
    ( 1       0.205      0.001) // 1: front-top-right
    (-0.75    0.08       0.001) // 2: front-mid-left
    ( 1       0.08       0.001) // 3: front-mid-right
    (-0.75   -0.026      0.001) // 4: front-bed-left
    ( 1      -0.026      0.001) // 5: front-bed-right
    
    (-0.75    0.205      0    ) // 6: back-top-left
    ( 1       0.205      0    ) // 7: back-top-right
    (-0.75    0.08       0    ) // 8: back-mid-left
    ( 1       0.08       0    ) // 9: back-mid-right
    (-0.75   -0.026      0    ) // 10: back-bed-left
    ( 1      -0.026      0    ) // 11: back-bed-right
);

blocks
(
    // Block 0: upper fluid (0.08 to 0.205)
    // 578 x 20, graded up (cells get larger towards surface)
    hex (8 9 7 6 2 3 1 0)     (578 20 1) simpleGrading (1 4 1)
    
    // Block 1: near bed fluid (-0.026 to 0.08)
    // 578 x 45, graded up (cells get larger towards mid, so they are tiny at the bed)
    hex (10 11 9 8 4 5 3 2)   (578 45 1) simpleGrading (1 8 1)
);

edges
(
);

patches
(
    patch inlet
    (
        (4 10 8 2)
        (2 8 6 0)
    )
    patch outlet
    (
        (7 1 3 9)
        (9 3 5 11)
    )
    symmetryPlane surface
    (
        (6 7 1 0)
    )
    wall bottom
    (
        (10 11 5 4)
    )
    empty lateralfront
    (
        (4 5 3 2)
        (2 3 1 0)
    )
    empty lateralback
    (
        (10 11 9 8)
        (8 9 7 6)
    )
);

mergePatchPairs
(
);
