// Cylinder: D=0.05m, R=0.025m (from reference 2DPipelineScour case)
// Seabed patch:   y = -0.025 m
// Cylinder centre: y = 0.0 m (sits ON the bed, no gap)
// STL bounding box: (-0.025 -0.025 -5) to (0.025 0.025 5)
// locationInMesh: inside fluid, outside cylinder
// locationInMesh: inside fluid, outside cylinder
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    cylinder.stl
    {
        type triSurfaceMesh;
        name cylinder;
    }
};

castellatedMeshControls
{
    maxLocalCells        2000000;
    maxGlobalCells       4000000;
    minRefinementCells   0;
    nCellsBetweenLevels  2;
    maxLoadUnbalance     0.10;
    allowFreeStandingZoneFaces true;

    features
    (
        {
            file "cylinder.eMesh";
            level 3;
        }
    );

    refinementSurfaces
    {
        cylinder
        {
            level (4 4);
            patchInfo { type wall; inGroups (wall); }
        }
    }

    refinementRegions
    {
        cylinder { mode inside; levels ((4 4)); }
    }

    locationInMesh     (0.5 0.1 0.0005);
    resolveFeatureAngle 30;
}

snapControls
{
    nSmoothPatch        3;
    tolerance           2.0;
    nSolveIter          300;
    nRelaxIter          5;
    nFeatureSnapIter    10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes       true;
    expansionRatio      1.2;
    finalLayerThickness 0.3;
    minThickness        0.1;
    layers {}
    nGrow               0;
    featureAngle        60;
    nRelaxIter          3;
    nSmoothSurfaceNormals 1;
    nSmoothNormals      3;
    nSmoothThickness    10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle  90;
    nBufferCellsNoExtrude 0;
    nLayerIter          50;
}

meshQualityControls
{
    maxNonOrtho         65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave          80;
    minFlatness         0.5;
    minVol              1e-18;
    minTetQuality       -1e+30;
    minArea             -1;
    minTwist            0.02;
    minDeterminant      0.001;
    minFaceWeight       0.05;
    minVolRatio         0.01;
    minTriangleTwist    -1;
    nSmoothScale        4;
    errorReduction      0.75;
    relaxed { maxNonOrtho 75; }
}

writeFlags ( scalarLevels layerSets layerFields );

mergeTolerance  1e-6;

