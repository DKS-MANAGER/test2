  Project     : 2D Pipeline Scour Morphodynamics
  Author      : Divyansh Kumar Singh
  Level       : Postgraduate Research
  Description : Simulation of hydrodynamics and morphodynamic scour around
                a pipeline using the sedExnerFoam solver.
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      faMeshDefinition;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

polyMeshPatches ( "bottom" );

boundary
{
    inletFa
    {
        type patch;
        neighbourPolyPatch inlet;
    }
    outletFa
    {
        type patch;
        neighbourPolyPatch outlet;
    }
    lateralfrontFa
    {
        type empty;
        neighbourPolyPatch lateralfront;
    }
    lateralbackFa
    {
        type empty;
        neighbourPolyPatch lateralback;
    }
}

defaultPatch
{
    name defaultFa;
    type empty;
}

