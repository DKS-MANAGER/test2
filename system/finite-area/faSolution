/*---------------------------------------------------------------------------*\
  Project     : 2D Pipeline Scour Morphodynamics
  Author      : Divyansh Kumar Singh
  Level       : Postgraduate Research
  Description : Simulation of hydrodynamics and morphodynamic scour around
                a pipeline using the sedExnerFoam solver.
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      faSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
//
// Finite-area linear system solvers.
// sedExnerFoam solves for 'zb' (bed elevation areaScalarField).
// The previous entry used key 'h' which is not the field name — the
// solver would fall through to a default (or abort) silently.

solvers
{
    zb
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
    }
}

// ************************************************************************* //