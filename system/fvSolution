// FIX (SIGFPE at Time=0.001, PIMPLE iter 1, before any solver output):
//
// Root cause: correctPhi yes + moveMeshOuterCorrectors yes causes
// mesh.controlledUpdate() + correctPhi.H to run at the START of every
// PIMPLE iteration, including step 2.
//
// At step 2, the Courant number jumped from 0.066 -> 0.282 after step 1
// (inlet corner velocity gradient: fixedValue (0.4 0 0) meets noSlip bottom).
// correctPhi solves: div(phi_corr) = div(U) over the face flux field.
// With the large Co jump and no mesh motion to justify the correction,
// the pcorr GAMG solve produces face fluxes with 1/deltaCoeffs -> large
// values at skewed inlet-corner faces -> overflow -> SIGFPE.
//
// Fix: correctPhi no + moveMeshOuterCorrectors no for Phase 1 (bedMotion off).
// These must be re-enabled for Phase 2 (bedMotion on, mesh actually moves).
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}

solvers
{
    cellDisplacement
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-5;
        relTol          0;
    }
    cellDisplacementFinal
    {
        $cellDisplacement;
        relTol          0;
    }

    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-6;
        relTol          0.01;
    }
    pFinal
    {
        $p;
        tolerance       1e-6;
        relTol          0;
    }

    pcorr
    {
        $p;
        tolerance       1e-4;
        relTol          0;
    }
    pcorrFinal
    {
        $pcorr;
        relTol          0;
    }

    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0.01;
    }
    UFinal
    {
        $U;
        relTol          0;
    }

    k
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.01;
    }
    kFinal
    {
        $k;
        relTol          0;
    }

    omega
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.01;
    }
    omegaFinal
    {
        $omega;
        relTol          0;
    }

    Cs
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.01;
    }
    CsFinal
    {
        $Cs;
        relTol          0;
    }

    h
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          0.01;
    }
    hFinal
    {
        $h;
        relTol          0;
    }
}

PIMPLE
{
    nCorrectors              2;
    nNonOrthogonalCorrectors 2;
    pRefCell                 0;
    pRefValue                0;

    // PHASE 1 (bedMotion off): mesh never moves, correctPhi and
    // moveMeshOuterCorrectors must be OFF to avoid spurious flux
    // corrections that cause SIGFPE at step 2.
    //
    // *** PHASE 2 SWITCH: change BOTH to 'yes' ***
    //   correctPhi               yes;
    //   moveMeshOuterCorrectors  yes;
    correctPhi               yes;
    moveMeshOuterCorrectors  yes;
}

relaxationFactors
{
    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        k               0.7;
        omega           0.7;
        Cs              0.5;
        cellDisplacement 0.5;
    }
}

