// TWO-PHASE RUN STRATEGY:
// Phase 1 (this file): bedMotion=off, spin-up 0->2s, fixed deltaT=5e-4.
//   Goal: develop fully turbulent flow profile before any bed evolution.
// Phase 2: copy bedloadProperties_phase2 -> bedloadProperties,
//   set startFrom latestTime, endTime 45, re-enable adjustTimeStep.
//   morphoAccFactor=10 then accelerates scour over 45s physical.
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application         sedExnerFoam;

startFrom           latestTime;
startTime           0;
stopAt              endTime;
endTime             2;

deltaT              5e-4;

writeControl        adjustableRunTime;
writeInterval       0.5;
purgeWrite          0;
writeFormat         binary;
writePrecision      6;
writeCompression    false;
timeFormat          general;
timePrecision       6;
runTimeModifiable   yes;
adjustTimeStep      no;

// All custom libraries from sedExnerFoam user build
libs
(
    "libsedimentBed.so"
    "libbedloadModels.so"
    "libcriticalShieldsModels.so"
    "libroughWallFunctions.so"
    "libsettlingModels.so"
    "libprojectedFiniteArea.so"
);

functions
{
    scourDepth
    {
        type            surfaceFieldValue;
        libs            ("libfieldFunctionObjects.so");
        writeControl    writeTime;
        log             yes;
        writeFields     no;
        regionType      patch;
        name            bottom;
        operation       min;
        fields          (pointDisplacement);
    }
}

